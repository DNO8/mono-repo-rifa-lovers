generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters", "partialIndexes"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["public"]
}

}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model schema_migrations {
  version String @id @db.VarChar(255)

  @@schema("auth")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model sessions {
  id                     String           @id @db.Uuid
  user_id                String           @db.Uuid
  created_at             DateTime?        @db.Timestamptz(6)
  updated_at             DateTime?        @db.Timestamptz(6)
  factor_id              String?          @db.Uuid
  aal                    aal_level?
  not_after              DateTime?        @db.Timestamptz(6)
  refreshed_at           DateTime?        @db.Timestamp(6)
  user_agent             String?
  ip                     String?          @db.Inet
  tag                    String?
  oauth_client_id        String?          @db.Uuid
  refresh_token_hmac_key String?
  refresh_token_counter  BigInt?
  scopes                 String?
  mfa_amr_claims         mfa_amr_claims[]
  refresh_tokens         refresh_tokens[]
  oauth_clients          oauth_clients?   @relation(fields: [oauth_client_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users                  auth_users       @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([not_after(sort: Desc)])
  @@index([oauth_client_id])
  @@index([user_id])
  @@index([user_id, created_at], map: "user_id_created_at_idx")
  @@schema("auth")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model sso_domains {
  id              String        @id @db.Uuid
  sso_provider_id String        @db.Uuid
  domain          String
  created_at      DateTime?     @db.Timestamptz(6)
  updated_at      DateTime?     @db.Timestamptz(6)
  sso_providers   sso_providers @relation(fields: [sso_provider_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([sso_provider_id])
  @@schema("auth")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model sso_providers {
  id                String              @id @db.Uuid
  resource_id       String?
  created_at        DateTime?           @db.Timestamptz(6)
  updated_at        DateTime?           @db.Timestamptz(6)
  disabled          Boolean?
  saml_providers    saml_providers[]
  saml_relay_states saml_relay_states[]
  sso_domains       sso_domains[]

  @@index([resource_id], map: "sso_providers_resource_id_pattern_idx")
  @@schema("auth")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model auth_users {
  instance_id                 String?                @db.Uuid
  id                          String                 @id @db.Uuid
  aud                         String?                @db.VarChar(255)
  role                        String?                @db.VarChar(255)
  email                       String?                @unique(map: "users_email_partial_key", where: raw("(is_sso_user = false)")) @db.VarChar(255)
  encrypted_password          String?                @db.VarChar(255)
  email_confirmed_at          DateTime?              @db.Timestamptz(6)
  invited_at                  DateTime?              @db.Timestamptz(6)
  confirmation_token          String?                @unique(map: "confirmation_token_idx", where: raw("((confirmation_token)::text !~ '^[0-9 ]*$'::text)")) @db.VarChar(255)
  confirmation_sent_at        DateTime?              @db.Timestamptz(6)
  recovery_token              String?                @unique(map: "recovery_token_idx", where: raw("((recovery_token)::text !~ '^[0-9 ]*$'::text)")) @db.VarChar(255)
  recovery_sent_at            DateTime?              @db.Timestamptz(6)
  email_change_token_new      String?                @unique(map: "email_change_token_new_idx", where: raw("((email_change_token_new)::text !~ '^[0-9 ]*$'::text)")) @db.VarChar(255)
  email_change                String?                @db.VarChar(255)
  email_change_sent_at        DateTime?              @db.Timestamptz(6)
  last_sign_in_at             DateTime?              @db.Timestamptz(6)
  raw_app_meta_data           Json?
  raw_user_meta_data          Json?
  is_super_admin              Boolean?
  created_at                  DateTime?              @db.Timestamptz(6)
  updated_at                  DateTime?              @db.Timestamptz(6)
  phone                       String?                @unique
  phone_confirmed_at          DateTime?              @db.Timestamptz(6)
  phone_change                String?                @default("")
  phone_change_token          String?                @default("") @db.VarChar(255)
  phone_change_sent_at        DateTime?              @db.Timestamptz(6)
  confirmed_at                DateTime?              @default(dbgenerated("LEAST(email_confirmed_at, phone_confirmed_at)")) @db.Timestamptz(6)
  email_change_token_current  String?                @unique(map: "email_change_token_current_idx", where: raw("((email_change_token_current)::text !~ '^[0-9 ]*$'::text)")) @default("") @db.VarChar(255)
  email_change_confirm_status Int?                   @default(0) @db.SmallInt
  banned_until                DateTime?              @db.Timestamptz(6)
  reauthentication_token      String?                @unique(map: "reauthentication_token_idx", where: raw("((reauthentication_token)::text !~ '^[0-9 ]*$'::text)")) @default("") @db.VarChar(255)
  reauthentication_sent_at    DateTime?              @db.Timestamptz(6)
  is_sso_user                 Boolean                @default(false)
  deleted_at                  DateTime?              @db.Timestamptz(6)
  is_anonymous                Boolean                @default(false)
  identities                  identities[]
  mfa_factors                 mfa_factors[]
  oauth_authorizations        oauth_authorizations[]
  oauth_consents              oauth_consents[]
  one_time_tokens             one_time_tokens[]
  sessions                    sessions[]
  webauthn_challenges         webauthn_challenges[]
  webauthn_credentials        webauthn_credentials[]
  users                       public_users?

  @@index([instance_id])
  @@index([is_anonymous])
  @@map("users")
  @@schema("auth")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model webauthn_challenges {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String?     @db.Uuid
  challenge_type String
  session_data   Json
  created_at     DateTime    @default(now()) @db.Timestamptz(6)
  expires_at     DateTime    @db.Timestamptz(6)
  users          auth_users? @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([expires_at])
  @@index([user_id])
  @@schema("auth")
}

model webauthn_credentials {
  id               String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String     @db.Uuid
  credential_id    Bytes      @unique
  public_key       Bytes
  attestation_type String     @default("")
  aaguid           String?    @db.Uuid
  sign_count       BigInt     @default(0)
  transports       Json       @default("[]")
  backup_eligible  Boolean    @default(false)
  backed_up        Boolean    @default(false)
  friendly_name    String     @default("")
  created_at       DateTime   @default(now()) @db.Timestamptz(6)
  updated_at       DateTime   @default(now()) @db.Timestamptz(6)
  last_used_at     DateTime?  @db.Timestamptz(6)
  users            auth_users @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id])
  @@schema("auth")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model lucky_passes {
  id            String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  raffle_id     String?            @db.Uuid
  user_id       String?            @db.Uuid
  user_pack_id  String?            @db.Uuid
  status        lucky_pass_status? @default(active)
  is_winner     Boolean?           @default(false)
  created_at    DateTime?          @default(now()) @db.Timestamp(6)
  ticket_number Int?
  raffles       raffles?           @relation(fields: [raffle_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users         public_users?      @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user_packs    user_packs?        @relation(fields: [user_pack_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  prize_winners prize_winners?

  @@index([raffle_id], map: "idx_lucky_raffle")
  @@index([raffle_id, status], map: "idx_lucky_raffle_status")
  @@index([user_id], map: "idx_lucky_user")
  @@index([user_pack_id], map: "idx_lucky_userpack")
  @@schema("public")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model milestones {
  id             String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  raffle_id      String?   @db.Uuid
  name           String?   @db.VarChar(150)
  required_packs Int?
  sort_order     Int?
  is_unlocked    Boolean?  @default(false)
  unlocked_at    DateTime? @db.Timestamp(6)
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  raffles        raffles?  @relation(fields: [raffle_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  prizes         prizes[]

  @@index([raffle_id], map: "idx_milestones_raffle")
  @@schema("public")
}

model organizations {
  id         String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name       String         @db.VarChar(200)
  slug       String         @unique @db.VarChar(200)
  created_at DateTime?      @default(now()) @db.Timestamp(6)
  updated_at DateTime?      @default(now()) @db.Timestamp(6)
  raffles    raffles[]
  users      public_users[]

  @@schema("public")
}

model packs {
  id                  String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name                String?      @db.VarChar(100)
  price               Decimal?     @db.Decimal(10, 2)
  lucky_pass_quantity Int?
  is_featured         Boolean?     @default(false)
  is_pre_sale         Boolean?     @default(false)
  created_at          DateTime?    @default(now()) @db.Timestamp(6)
  user_packs          user_packs[]

  @@schema("public")
}

model payment_transactions {
  id                      String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  purchase_id             String?         @db.Uuid
  provider                String?         @db.VarChar(50)
  provider_transaction_id String?         @db.VarChar(255)
  amount                  Decimal?        @db.Decimal(12, 2)
  status                  payment_status? @default(created)
  created_at              DateTime?       @default(now()) @db.Timestamp(6)
  purchases               purchases?      @relation(fields: [purchase_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([provider_transaction_id], map: "idx_payment_provider_tx")
  @@schema("public")
}

model prize_winners {
  id            String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  prize_id      String?       @db.Uuid
  lucky_pass_id String?       @unique(map: "unique_lucky_pass_winner") @db.Uuid
  user_id       String?       @db.Uuid
  created_at    DateTime?     @default(now()) @db.Timestamp(6)
  lucky_passes  lucky_passes? @relation(fields: [lucky_pass_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  prizes        prizes?       @relation(fields: [prize_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users         public_users? @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([prize_id, lucky_pass_id], map: "unique_prize_ticket")
  @@index([lucky_pass_id], map: "idx_prize_winners_lucky")
  @@index([user_id], map: "idx_prize_winners_user")
  @@schema("public")
}

model prizes {
  id              String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  raffle_id       String?         @db.Uuid
  milestone_id    String?         @db.Uuid
  type            prize_type?
  name            String?         @db.VarChar(255)
  description     String?
  value_estimated Decimal?        @db.Decimal(12, 2)
  quantity        Int?            @default(1)
  created_at      DateTime?       @default(now()) @db.Timestamp(6)
  prize_winners   prize_winners[]
  milestones      milestones?     @relation(fields: [milestone_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  raffles         raffles?        @relation(fields: [raffle_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([raffle_id], map: "idx_prizes_raffle")
  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model purchases {
  id                   String                 @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  raffle_id            String?                @db.Uuid
  user_id              String?                @db.Uuid
  total_amount         Decimal?               @db.Decimal(12, 2)
  status               purchase_status?       @default(pending)
  created_at           DateTime?              @default(now()) @db.Timestamp(6)
  paid_at              DateTime?              @db.Timestamp(6)
  payment_transactions payment_transactions[]
  raffles              raffles?               @relation(fields: [raffle_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users                public_users?          @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user_packs           user_packs[]

  @@index([raffle_id], map: "idx_purchases_raffle")
  @@index([user_id], map: "idx_purchases_user")
  @@schema("public")
}

model raffle_progress {
  id                 String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  raffle_id          String?   @unique @db.Uuid
  packs_sold         Int?      @default(0)
  revenue_total      Decimal?  @db.Decimal(12, 2)
  percentage_to_goal Decimal?  @db.Decimal(5, 2)
  updated_at         DateTime? @default(now()) @db.Timestamp(6)
  raffles            raffles?  @relation(fields: [raffle_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

model raffles {
  id              String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organization_id String?          @db.Uuid
  title           String?          @db.VarChar(255)
  description     String?
  goal_packs      Int?             @default(5000)
  status          raffle_status?   @default(draft)
  start_date      DateTime?        @db.Timestamp(6)
  end_date        DateTime?        @db.Timestamp(6)
  created_at      DateTime?        @default(now()) @db.Timestamp(6)
  updated_at      DateTime?        @default(now()) @db.Timestamp(6)
  lucky_passes    lucky_passes[]
  milestones      milestones[]
  prizes          prizes[]
  purchases       purchases[]
  raffle_progress raffle_progress?
  organizations   organizations?   @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user_packs      user_packs[]

  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model user_packs {
  id           String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id      String?        @db.Uuid
  raffle_id    String?        @db.Uuid
  pack_id      String?        @db.Uuid
  purchase_id  String?        @db.Uuid
  quantity     Int?           @default(1)
  total_paid   Decimal?       @db.Decimal(10, 2)
  created_at   DateTime?      @default(now()) @db.Timestamp(6)
  lucky_passes lucky_passes[]
  packs        packs?         @relation(fields: [pack_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  purchases    purchases?     @relation(fields: [purchase_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  raffles      raffles?       @relation(fields: [raffle_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users        public_users?  @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([purchase_id], map: "idx_userpacks_purchase")
  @@index([raffle_id], map: "idx_userpacks_raffle")
  @@index([user_id], map: "idx_userpacks_user")
  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model public_users {
  id              String          @id @db.Uuid
  organization_id String?         @db.Uuid
  email           String?         @db.VarChar(255)
  first_name      String?         @db.VarChar(120)
  last_name       String?         @db.VarChar(120)
  role            user_role?      @default(customer)
  status          user_status?    @default(active)
  created_at      DateTime?       @default(now()) @db.Timestamp(6)
  updated_at      DateTime?       @default(now()) @db.Timestamp(6)
  phone_number    Decimal         @db.Decimal
  lucky_passes    lucky_passes[]
  prize_winners   prize_winners[]
  purchases       purchases[]
  user_packs      user_packs[]
  users           auth_users      @relation(fields: [id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  organizations   organizations?  @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("users")
  @@schema("public")
}

enum aal_level {
  aal1
  aal2
  aal3

  @@schema("auth")
}

enum code_challenge_method {
  s256
  plain

  @@schema("auth")
}

enum factor_status {
  unverified
  verified

  @@schema("auth")
}

enum factor_type {
  totp
  webauthn
  phone

  @@schema("auth")
}

enum oauth_authorization_status {
  pending
  approved
  denied
  expired

  @@schema("auth")
}

enum oauth_client_type {
  public
  confidential

  @@schema("auth")
}

enum oauth_registration_type {
  dynamic
  manual

  @@schema("auth")
}

enum oauth_response_type {
  code

  @@schema("auth")
}

enum one_time_token_type {
  confirmation_token
  reauthentication_token
  recovery_token
  email_change_token_new
  email_change_token_current
  phone_change_token

  @@schema("auth")
}

enum PaymentStatus {
  created
  pending
  approved
  rejected

  @@schema("public")
}

enum PrizeType {
  milestone
  flash

  @@schema("public")
}

enum PurchaseStatus {
  pending
  paid
  failed
  refunded

  @@schema("public")
}

enum lucky_pass_status {
  active
  used
  winner
  cancelled

  @@schema("public")
}

enum payment_status {
  created
  pending
  approved
  rejected

  @@schema("public")
}

enum prize_type {
  milestone
  flash

  @@schema("public")
}

enum purchase_status {
  pending
  paid
  failed
  refunded

  @@schema("public")
}

enum raffle_status {
  draft
  active
  sold_out
  closed
  drawn

  @@schema("public")
}

enum user_role {
  admin
  operator
  customer

  @@schema("public")
}

enum user_status {
  active
  blocked

  @@schema("public")
}
